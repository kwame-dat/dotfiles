[Unit]
  Description=cifs mount script
  Requires=network-online.target
  After=network-online.service

[Mount]
  What=//192.168.1.3/Iso
  Where=/home/tonyampomah/mnt/Iso
  Type=cifs
  Options=_netdev,credentials=/etc/samba/credentials/music-share,rw,file_mode=0777,dir_mode=0777
  DirectoryMode=0700

[Install]
  WantedBy=multi-user.target
