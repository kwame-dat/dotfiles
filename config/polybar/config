;; File Inclusion
include-file = ~/.config/polybar/colors.ini
include-file = ~/.config/polybar/modules.ini

[bar/main]
monitor = ${env:MONITOR:}
dpi = 192
width = 100%
height = 60
radius = 0.0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 0
line-color = ${colors.background}

padding-left = 3
padding-right = 0

module-margin-left = 2
module-margin-right = 2

font-0 = "Cantarell:size=10;0"
font-1 = "FontAwesome:size=10;0"
font-2 = "Cantarell:size=10;0"
font-3 = "Noto Sans Mono:size=10;0"

modules-left = cpu memory temperature xwindow 
modules-center = ewmh 
modules-right = networkspeedup networkspeeddown backlight pavolume battery xkeyboard time date

tray-position = right
tray-padding = 0
tray-maxsize = 40
tray-scale = 1.0

wm-restack = i3


[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0
