#!/bin/bash

if xrandr | grep -q "^DP1 connected"
then
    
    xrandr --output eDP1 --mode 3840x2160 \
           --pos 3840x0 --rotate normal \
           --output DP1 --primary --mode 3840x1600 \
           --pos 0x0 --rotate normal \
           --output DP2 --off \
           --output DP3 --off \
           --output VIRTUAL1 --off

    ln -sf /home/tonya/Repo/2Areas/dotfiles/.config/shell/Xresources-ultrawide /home/tonya/.Xresources
    xrdb -merge ~/.Xresources
else
    ln -sf /home/tonya/Repo/2Areas/dotfiles/.Xresources ~/
    xrdb -merge ~/.Xresources
fi
