;; File Inclusion
include-file = ~/.config/polybar/colors.ini
include-file = ~/.config/polybar/modules.ini

[bar/main]
monitor = ${env:MONITOR:}
dpi = 192
width = 100%
height = 70
radius = 0.0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 4
line-color = ${colors.alert}

padding-left = 0
padding-right = 0

module-margin-left = 2
module-margin-right = 2

font-0 = "Noto Sans:size=11;0"
font-1 = "FontAwesome:size=11;0"
font-2 = "Noto Sans:size=11;0"
font-3 = "Noto Sans Mono:size=11;0"

modules-left = ewmh cpu temperature memory networkspeedup
modules-center = xwindow
modules-right = networkspeeddown backlight pavolume battery xkeyboard time date

tray-position = right
tray-padding = 0
tray-maxsize = 40
tray-scale = 1.0

wm-restack = i3


[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0
