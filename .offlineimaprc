[general]
accounts = Arksolutions, Emporium
maxsyncaccounts = 2
pythonfile = ~/Dotfiles/shell/+mu/lib.py

[DEFAULT]

[Account Arksolutions]
localrepository = LocalArksolutions
remoterepository = RepositoryArksolutions

[Repository LocalArksolutions]
type = Maildir
localfolders = ~/.mail/arksolutions.it

[Repository RepositoryArksolutions]
type = IMAP
remotehosteval = get_pass("Personal/Emails/arksolutions.it")["remotehost"]
remoteusereval = get_pass("Personal/Emails/arksolutions.it")["user"]
remotepasseval = get_pass("Personal/Emails/arksolutions.it")["password"]
ssl = true
maxconnections = 1
sslcacertfile = /usr/local/etc/openssl/cert.pem


[Account Emporium]
localrepository = LocalEmporium
remoterepository = RepositoryEmporium

[Repository LocalEmporium]
type = Maildir
localfolders = ~/.mail/emporium.co.uk

[Repository RepositoryEmporium]
type = IMAP
remotehosteval = get_pass("Work/Emails/emporium.co.uk")["remotehost"]
remoteusereval = get_pass("Work/Emails/emporium.co.uk")["user"]
remotepasseval = get_pass("Work/Emails/emporium.co.uk")["password"]
ssl = true
maxconnections = 1
sslcacertfile = /usr/local/etc/openssl/cert.pem
