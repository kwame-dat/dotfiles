[general]
accounts = Arksolutions
maxsyncaccounts = 1
pythonfile = ~/Repo/Dotfiles/shell/+mu/lib.py

[Account Arksolutions]
localrepository = LocalArksolutions
remoterepository = RepositoryArksolutions

[Repository LocalArksolutions]
type = Maildir
localfolders = ~/.mail/arksolutions.it

[Repository RepositoryArksolutions]
type = IMAP
remotehosteval = get_pass("Emails/arksolutions.it")["remotehost"]
remoteusereval = get_pass("Emails/arksolutions.it")["user"]
remotepasseval = get_pass("Emails/arksolutions.it")["password"]
ssl = true
maxconnections = 1
sslcacertfile = /usr/local/etc/openssl/cert.pem
