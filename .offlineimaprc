[general]
accounts = Netsells, Arksolutions
maxsyncaccounts = 2
pythonfile = ~/Repo/2Areas/Dotfiles/shell/+mu/lib.py

autorefresh = 0.5
quick = 10

[Account Arksolutions]
localrepository = LocalArksolutions
remoterepository = RepositoryArksolutions

[Repository LocalArksolutions]
type = Maildir
localfolders = ~/.mail/arksolutions.it

[Repository RepositoryArksolutions]
type = IMAP
remotehosteval = get_pass("emails/arksolutions.it")["remotehost"]
remoteusereval = get_pass("emails/arksolutions.it")["user"]
remotepasseval = get_pass("emails/arksolutions.it")["password"]
ssl = true
maxconnections = 1
sslcacertfile = /usr/local/etc/openssl/cert.pem

[Account Netsells]
localrepository = LocalNetsells
remoterepository = RepositoryNetsells

[Repository LocalNetsells]
type = Maildir
localfolders = ~/.mail/netsells.co.uk

[Repository RepositoryNetsells]
type = IMAP
remotehosteval = get_pass("emails/netsells.co.uk")["remotehost"]
remoteusereval = get_pass("emails/netsells.co.uk")["user"]
remotepasseval = get_pass("emails/netsells.co.uk")["password"]
ssl = true
maxconnections = 1
sslcacertfile = /usr/local/etc/openssl/cert.pem
