[general]
accounts = Spiritual, Personal, Work
maxsyncaccounts = 1
pythonfile = ~/Repo/Personal/2Areas/Dotfiles/shell/+mu/lib.py

autorefresh = 0.5
quick = 10

[Account Spiritual]
localrepository = LocalSpiritual
remoterepository = RemoteSpiritual

[Repository LocalSpiritual]
type = Maildir
localfolders = ~/.mail/spiritual

[Repository RemoteSpiritual]
type = Gmail
remotehosteval = get_pass("spiritual/email/gmail.com")["remotehost"]
remoteusereval = get_pass("spiritual/email/gmail.com")["user"]
remotepasseval = get_pass("spiritual/email/gmail.com")["password"]
ssl = yes
maxconnections = 1
sslcacertfile = /usr/local/etc/openssl/cert.pem

[Account Personal]
localrepository = LocalPersonal
remoterepository = RemotePersonal

[Repository LocalPersonal]
type = Maildir
localfolders = ~/.mail/personal

[Repository RemotePersonal]
type = IMAP
remotehosteval = get_pass("personal/email/arksolutions.it")["remotehost"]
remoteusereval = get_pass("personal/email/arksolutions.it")["user"]
remotepasseval = get_pass("personal/email/arksolutions.it")["password"]
ssl = yes
maxconnections = 1
sslcacertfile = /usr/local/etc/openssl/cert.pem

[Account Work]
localrepository = LocalWork
remoterepository = RemoteWork

[Repository LocalWork]
type = Maildir
localfolders = ~/.mail/work

[Repository RemoteWork]
type = IMAP
remotehosteval = get_pass("work/email/netsells.co.uk")["remotehost"]
remoteusereval = get_pass("work/email/netsells.co.uk")["user"]
remotepasseval = get_pass("work/email/netsells.co.uk")["password"]
ssl = yes
maxconnections = 1
sslcacertfile = /usr/local/etc/openssl/cert.pem
