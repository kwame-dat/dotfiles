localfolders = ~/Maildir/arksolutions

[Repository arksolutions_remote]
type = IMAP
remotehosteval = get_pass("2Areas/Personal/Emails/Arksolutions")["remotehost"]
remoteusereval = get_pass("2Areas/Personal/Emails/Arksolutions")["user"]
remotepasseval = get_pass("2Areas/Personal/Emails/Arksolutions")["password"]
ssl = yes
holdconnectionopen = true
keepalive = 60
