remoterepository = thetrainline_remote

[Repository thetrainline_local]
type = Maildir
localfolders = ~/Maildir/thetrainline

[Repository thetrainline_remote]
type = IMAP
ssl = yes
readonly = true
remotehosteval = get_pass("work/ttl/email")["remotehost"]
remoteusereval = get_pass("work/ttl/email")["user"]
remotepasseval = get_pass("work/ttl/email")["password"]
