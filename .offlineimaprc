[general]
accounts = Arksolutions, Emporium
maxsyncaccounts = 2
pythonfile = ~/Dotfiles/shell/+mu/lib.py

[DEFAULT]

[Account Arksolutions]
localrepository = LocalArksolutions
remoterepository = RepositoryArksolutions
synclabels = yes
labelsheader = X-Keywords
maxconnections = 2

[Repository LocalArksolutions]
type = ArksolutionsMaildir
localfolders = ~/.mail/arksolutions.it

[Repository RepositoryArksolutions]
type = IMAP
remotehost = get_pass("2 Areas/Personal/Emails/arksolutions.it")["remotehost"]
remoteusereval = get_pass("2 Areas/Personal/Emails/arksolutions.it")["user"]
remotepasseval = get_pass("2 Areas/Personal/Emails/arksolutions.it")["password"]
realdelete=no
ssl = true
sslcacertfile = /usr/local/etc/openssl/cert.pem

###
[Account Emporium]
localrepository = LocalEmporium
remoterepository = RepositoryEmporium
synclabels = yes
labelsheader = X-Keywords
maxconnections = 2

[Repository LocalEmporium]
type = GmailMaildir
localfolders = ~/.mail/emporium.co.uk

[Repository RepositoryEmporium]
type = IMAP
remotehost = get_pass("2 Areas/Work/email")["remotehost"]
remoteusereval = get_pass("2 Areas/Work/email")["user"]
remotepasseval = get_pass("2 Areas/Work/email")["password"]
realdelete=no
ssl = true
sslcacertfile = /usr/local/etc/openssl/cert.pem
