[general]
accounts = jw, arksolutions, netsells
maxsyncaccounts = 1
pythonfile = ~/Repo/2Areas/dotfiles/shell/mu/lib.py

autorefresh = 0.5
quick = 10

# _-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-

[Account jw]
localrepository = jw_local
remoterepository = jw_remote

[Repository jw_local]
type = Maildir
localfolders = ~/Maildir/jw

[Repository jw_remote]
type = Gmail
remotehosteval = get_pass("2Areas/Spiritual/Email")["remotehost"]
remoteusereval = get_pass("2Areas/Spiritual/Email")["user"]
remotepasseval = get_pass("2Areas/Spiritual/Email")["password"]
ssl = yes
holdconnectionopen = true
keepalive = 60
sslcacertfile = /etc/ssl/certs/ca-certificates.crt

# _-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-_-

[Account arksolutions]
