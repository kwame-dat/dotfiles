### tony@arksolustions.it #########################################
IMAPAccount arksolutions
Host imappro.zoho.com
Port 993
User tony@arksolutions.it
PassCmd "pass 2Areas/emails/arksolutions.it/zoho.com"
SSLType IMAPS
SSLVersions TLSv1.2
CertificateFile ~/.ca-bundle.crt

IMAPStore arksolutions-remote
Account arksolutions

MaildirStore arksolutions-local
Path ~/Maildir/tony@arksolutions.it/
Inbox ~/Maildir/tony@arksolutions.it/Inbox
Trash ~/Maildir/tony@arksolutions.it/Trash
SubFolders Verbatim

Channel arksolutions
Master :arksolutions-remote:
Slave :arksolutions-local:
Patterns *
Expunge None
CopyArrivalDate yes
Sync All
Create Both
SyncState *


### itechytony@gmail #########################################
IMAPAccount itechytony-gmail
# Address to connect to
Host imap.gmail.com
User itechytony@gmail.com
PassCmd "pass 2Areas/emails/google.com"
SSLType IMAPS
CertificateFile ~/.ca-bundle.crt

IMAPStore itechytony-gmail-remote
Account itechytony-gmail

MaildirStore itechytony-gmail-local
SubFolders Verbatim
# The trailing "/" is important
Path ~/Maildir/itechytony@gmail.com/
Inbox ~/Maildir/itechytony@gmail.com/Inbox

Channel itechytony-gmail
Master :itechytony-gmail-remote:
Slave :itechytony-gmail-local:
# Exclude everything under the internal [Gmail] folder, except the interesting folders
Patterns * ![Gmail]* "[Gmail]/Sent Mail" "[Gmail]/Starred" "[Gmail]/All Mail"
# Or include everything
#Patterns *
# Automatically create missing mailboxes, both locally and on the server
Create Both
# Save the synchronization state files in the relevant directory
SyncState *


