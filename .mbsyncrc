### tampomah@emporium.co.uk #########################################
IMAPAccount emporium
Host exchange.eandl.co.uk
User eandl\\tampomah
PassCmd "pass 2Areas/emails/emporium.co.uk"
# SSLType IMAPS
# SSLVersion TLSv1.2
AuthMechs PLAIN
CertificateFile ~/.ca-bundle.crt

IMAPStore emporium-remote
Account emporium

MaildirStore emporium-local
Path ~/Maildir/tampomah@emporium.co.uk/
Inbox ~/Maildir/tampomah@emporium.co.uk/Inbox

Channel emporium
Master :emporium-remote:
Slave :emporium-local:
# Include everything
Patterns "INBOX" "*"
# Automatically create missing mailboxes, both locally and on the server
Create Both
Sync All
# Save the synchronization state files in the relevant directory
SyncState *